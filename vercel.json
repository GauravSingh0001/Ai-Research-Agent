{
    "version": 2,
    "builds": [
        {
            "src": "api/index.py",
            "use": "@vercel/python@3.1.0",
            "config": {
                "pythonVersion": "3.11",
                "maxLambdaSize": "250mb"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/dashboard/index.html"
        }
    ],
    "env": {
        "PYTHONPATH": "./",
        "VERCEL": "1"
    }
}