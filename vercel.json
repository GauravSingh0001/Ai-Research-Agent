{
  "version": 2,
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/(.*\\.(js|css|png|svg|ico|json))$",
      "dest": "/dashboard/$1"
    },
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}